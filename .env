# Porta utilizada para executar a aplicação.
PORT=3000

# String de conexão com o banco de dados PostgreSQL.
# Formato:
# postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL="postgresql://postgres:admin@localhost:5432/tech_challenge_blog"

# Chave secreta utilizada para gerar e validar os tokens JWT.
# Em ambiente de produção, utilize uma chave forte e mantenha-a em segredo.
JWT_SECRET=supersecret