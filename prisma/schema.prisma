generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int    @id @default(autoincrement())
  email     String @unique
  password  String
  role      String @default("user")
  createdAt DateTime @default(now())
}

model Post {
  id      Int    @id @default(autoincrement())
  title   String
  content String
}